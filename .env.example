# ─────────────────────────────────────────────
# Antelligen Frontend — 환경변수 템플릿
# ─────────────────────────────────────────────
# 사용법: 이 파일을 `.env.local` 로 복사 후 실제 값을 채워 사용하세요.
# Next.js 16 환경변수 규칙: `NEXT_PUBLIC_` prefix 만 클라이언트 번들에 노출됨.

# ─────────────────────────────────────────────
# API Base URLs
# ─────────────────────────────────────────────

# 일반 백엔드 API 서버 주소 (uvicorn 포트와 일치)
NEXT_PUBLIC_API_BASE_URL=http://localhost:33333

# AI Agent API 서버 주소 (현재 backend 와 동일 host. 추후 분리 시 별도 URL)
NEXT_PUBLIC_AGENT_API_BASE_URL=http://localhost:33333

# ─────────────────────────────────────────────
# OAuth / 소셜 로그인
# ─────────────────────────────────────────────

# 카카오 OAuth 인증 링크 요청 경로 (backend 라우트와 일치)
NEXT_PUBLIC_KAKAO_LOGIN_PATH=/api/v1/kakao-authentication/request-oauth-link
